@tailwind base;
@tailwind components;
@tailwind utilities;

@layer components {
    .section {
        @apply min-h-screen px-4 py-16 sm:px-6 lg:px-8;
    }

    .section-title {
        @apply text-3xl font-bold text-primary mb-8 text-center;
    }
}

html {
    scroll-behavior: smooth;
}
